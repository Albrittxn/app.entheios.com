# Generated by `openssl rand -base64 32`. Used to sign session JWTs.
AUTH_SECRET=

# Resend API key (https://resend.com)
RESEND_API_KEY=

# Email address to send sign-in codes from. Must be on a verified Resend domain.
RESEND_FROM_EMAIL="Atlas <portal@entheios.com>"

# Vercel Edge Config — connection URL (with read-only token). Provisioned
# automatically when this project is set up; you don't normally edit by hand.
EDGE_CONFIG=

# These three power the admin "add/remove email" writes. Together they let
# the app PATCH the Edge Config items endpoint.
EDGE_CONFIG_ID=
VERCEL_TEAM_ID=
VERCEL_API_TOKEN=
